[flake8]
max-line-length = 88
extend-ignore = E203, W503, D100, D101, D102, D103, D104, D105, D106
exclude =
	.venv,
	__pycache__,
	frontend/.next,
	backend/*/migrations

# Ignore docstring requirements and some import checks in autogenerated files
per-file-ignores =
	backend/*/migrations/*.py: D100,D101,D102,D103,D104,D105,D106,F401
	frontend/.next/**: ALL
