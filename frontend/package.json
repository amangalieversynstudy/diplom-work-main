{
  "name": "rpg-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "eslint --ext .js,.jsx,.ts,.tsx . --fix",
    "prepare": "husky install",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\""
  },
  "dependencies": {
    "axios": "1.5.0",
    "next": "14.0.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "tailwindcss": "^3.4.8"
  },
  "devDependencies": {
    "eslint": "8.x",
    "eslint-config-next": "13.x",
    "eslint-plugin-react-hooks": "4.x",
    "eslint-plugin-jsx-a11y": "6.x",
    "prettier": "2.x",
    "eslint-config-prettier": "8.x",
    "husky": "8.x",
    "lint-staged": "14.x"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "**/*.{json,md}": [
      "prettier --write"
    ]
  }
}
